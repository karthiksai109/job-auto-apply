# ============================================================
# PLATFORM CREDENTIALS
# ============================================================
LINKEDIN_EMAIL=your_linkedin_email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password

INDEED_EMAIL=your_indeed_email@gmail.com
INDEED_PASSWORD=your_indeed_password

DICE_EMAIL=your_dice_email@gmail.com
DICE_PASSWORD=your_dice_password

MONSTER_EMAIL=your_monster_email@gmail.com
MONSTER_PASSWORD=your_monster_password

# ============================================================
# OPENAI API KEY (for AI-powered interview prep)
# Get from: https://platform.openai.com/api-keys
# ============================================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# EMAIL SETTINGS (for status reports & interview prep emails)
# For Gmail: use App Password (Google Account > Security > App passwords)
# ============================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_RECIPIENT=your_email@gmail.com

# ============================================================
# PERSONAL INFO
# ============================================================
FIRST_NAME=YourFirstName
LAST_NAME=YourLastName
PERSONAL_EMAIL=your_email@gmail.com
PERSONAL_PHONE=+10000000000
CITY=YourCity
STATE=YourState
ZIP_CODE=00000
ADDRESS=123 Main St, City, ST 00000
LINKEDIN_URL=https://www.linkedin.com/in/yourprofile/
GITHUB_URL=https://github.com/yourusername
PORTFOLIO_URL=https://yourportfolio.com
YEARS_EXPERIENCE=0
SALARY_EXPECTATION=0
EDUCATION_LEVEL=Master's
UNIVERSITY=Your University
DEGREE=Master of Science in Computer Science
GRADUATION_YEAR=2025
BTECH_YEAR=2022
DOB=2000-01-01
US_ENTRY_DATE=2023-01-01
OPT_START=2026-01-01

# ============================================================
# RESUME PATH
# ============================================================
RESUME_PATH=/path/to/your/resume.pdf

# ============================================================
# BROWSER SETTINGS
# ============================================================
HEADLESS=false
SLOW_MO=1.5
